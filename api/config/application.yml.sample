# Copy this to config/application.yml and fill in your values.
# This file is loaded by Figaro and values become ENV vars.

# Shared with rakamin-api — must match exactly for JWT to work
SECRET_KEY_BASE: "your_secret_key_base_here"

# Database (shared with rakamin-api)
DB_HOST: "localhost"
DB_PORT: "5432"
DB_NAME: "rakamin_development"
DB_USERNAME: "postgres"
DB_PASSWORD: ""

# AI Interview specific
GEMINI_API_KEY: "your_gemini_api_key"
GEMINI_LIVE_MODEL: "gemini-2.0-flash-live-001"
GEMINI_FLASH_MODEL: "gemini-2.0-flash-001"
GEMINI_PRO_MODEL: "gemini-2.0-pro-001"

# App URL (for invite links)
APP_BASE_URL: "http://localhost:3001"

# Token settings (should match rakamin-api)
TOKEN_EXPIRATION_TIME: "259200"  # 3 days in seconds

# CORS
ALLOWED_ORIGINS: "*"

# Sidekiq / Redis
REDIS_URL: "redis://localhost:6379/1"
